{
  "name": "generator-lit-base",
  "version": "1.5.5",
  "description": "Generator to create a improvment Lit WebComponent from @open-wc",
  "homepage": "https://github.com/manufosela/generator-litelement-webcomponent",
  "author": {
    "name": "manufosela",
    "email": "manufosela@gmail.com",
    "url": "https://manufosela.es"
  },
  "type": "module",
  "files": [
    "generators"
  ],
  "main": "generators/app/index.js",
  "keywords": [
    "lit",
    "webcomponents",
    "scafolding",
    "yeoman-generator"
  ],
  "devDependencies": {
    "coveralls": "^3.1.1",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-xo": "^0.43.1",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.0",
    "prettier": "^3.0.2",
    "vitest": "^1.6.0",
    "yeoman-assert": "^3.1.1",
    "yeoman-test": "^7.4.0"
  },
  "engines": {
    "npm": ">= 4.0.0"
  },
  "dependencies": {
    "yeoman-generator": "^5.9.0",
    "chalk": "^5.3.0",
    "yosay": "^2.0.2"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add"
    ],
    "*.json": [
      "prettier --write",
      "git add"
    ]
  },
  "eslintConfig": {
    "extends": [
      "xo",
      "prettier"
    ],
    "env": {
      "jest": true,
      "node": true
    },
    "rules": {
      "prettier/prettier": "error"
    },
    "plugins": [
      "prettier"
    ]
  },
  "scripts": {
    "pretest": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": "https://github.com/manufosela/generator-litelement-webcomponent.git",
  "license": "Apache-2.0"
}
